
# --- Configuration for the external MCP Server that the OMOP Agent connects to ---
# In a real scenario, this would be a separate, long-running service.
# For our test, we can use a mock server address.
MCP_SERVER_URL=http://localhost:8080

# --- Configuration for the OMOP Database Agent's own server ---
# This is the address the Orchestrator will use to contact the OMOP Agent.
OMOP_AGENT_HOST=127.0.0.1
OMOP_AGENT_PORT=8002
OMOP_AGENT_URL=http://127.0.0.1:8002
